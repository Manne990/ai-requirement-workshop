# Copy this file to .env.local for local development.
# Keep real tokens in .env.local, Vercel environment variables, or Supabase
# secret storage. Never commit production secrets.

# Local Vite BFF token for /api/codex/*.
OPENAI_API_KEY=""

# Optional local alias for the same Codex/OpenAI boundary.
CODEX_API_TOKEN=""

# Optional local disk backup override for /api/workshops/backup.
AI_REQUIREMENT_WORKSHOP_BACKUP_DIR=""

# Optional dev/server-backed workshop record store.
# Set to "/api/workshops" to use the server record boundary instead of browser
# IndexedDB/localStorage. Production should back this endpoint with verified
# organization auth and durable storage.
VITE_WORKSHOP_RECORD_ENDPOINT=""
AI_REQUIREMENT_WORKSHOP_SERVER_STORE_DIR=""

# Optional local telemetry JSONL target for /api/mission-control/telemetry.
AI_REQUIREMENT_WORKSHOP_TELEMETRY_DIR=""

# Optional server-side Codex audit JSONL target for /api/codex/workshop-turn.
AI_REQUIREMENT_WORKSHOP_CODEX_AUDIT_DIR=""

# Optional browser-safe endpoint for Mission Control telemetry ingestion.
# Leave empty to keep telemetry local to browser storage only.
VITE_MISSION_CONTROL_TELEMETRY_ENDPOINT=""

# Browser-safe Supabase config for future production implementation.
VITE_SUPABASE_URL="https://example-project.supabase.co"
VITE_SUPABASE_ANON_KEY="public-anon-key"

# Server-only production value for Vercel Functions. Never prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=""
